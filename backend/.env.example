DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local development example. Replace localhost with your hosted MySQL values
# before using this on Railway or any deployed environment.
DATABASE_URL=mysql+pymysql://mindbloom_user:change-me@your-mysql-host:3306/mindbloom?charset=utf8mb4
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=mindbloom_user
MYSQL_PASSWORD=tiger
MYSQL_DATABASE=mindbloom
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
